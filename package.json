{
  "name": "bold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "build:api": "pnpm --filter @boldmeet/shared build && pnpm --filter @boldmeet/api db:generate && pnpm --filter @boldmeet/api build",
    "start:api": "pnpm --filter @boldmeet/api start:prod",
    "build:web": "pnpm --filter @boldmeet/shared build && pnpm --filter @boldmeet/web db:generate && pnpm --filter @boldmeet/web build",
    "start:web": "pnpm --filter @boldmeet/web start",
    "db:generate": "pnpm --filter @boldmeet/api db:generate",
    "db:migrate": "pnpm --filter @boldmeet/api db:migrate",
    "db:push": "pnpm --filter @boldmeet/api db:push",
    "db:studio": "pnpm --filter @boldmeet/api db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9.15.0"
  }
}
