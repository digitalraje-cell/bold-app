generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum ParticipantRole {
  HOST
  CO_HOST
  PANELIST
  PARTICIPANT
  MODERATOR
}

enum RoomMode {
  MEETING
  WEBINAR
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum WebinarType {
  LIVE
  EVERGREEN
}

enum WebinarStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
  ARCHIVED
}

enum VideoSourceProvider {
  YOUTUBE
  BOLD_VIDEO
}

enum WebinarModeratorRole {
  MODERATOR
  CO_MODERATOR
}

enum RecordingProviderType {
  YOUTUBE
  BOLD_VIDEO
  STORAGE
}

enum ParticipantStatus {
  WAITING
  ADMITTED
  REMOVED
  LEFT
}

enum ChatMode {
  EVERYONE
  HOST_ONLY
  HOST_PANELISTS
  DISABLED
}

enum StreamVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum StreamStatus {
  IDLE
  LIVE
  ENDED
  ERROR
}

enum StreamingProviderType {
  NONE
  YOUTUBE_RTMP
  CUSTOM_RTMP
}

enum OtpChannel {
  EMAIL
  WHATSAPP
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  role          UserRole  @default(USER)
  subscriptionPlan SubscriptionPlan @default(FREE)
  subscriptionExpiresAt DateTime?
  isVerified    Boolean   @default(false)
  verifiedAt    DateTime?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  hostedMeetings Meeting[]       @relation("MeetingHost")
  hostedWebinars Webinar[]       @relation("WebinarHost")
  participants   Participant[]
  youtubeAccount YouTubeAccount?
  chatMessages   ChatMessage[]
  subscriptionPayments SubscriptionPayment[]
  pendingPayments      PendingPayment[]
  roadmapVotes         RoadmapVote[]

  @@map("users")
}

model OtpVerification {
  id        String    @id @default(cuid())
  email     String
  codeHash  String
  channel   OtpChannel @default(EMAIL)
  expiresAt DateTime
  attempts  Int       @default(0)
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([email, createdAt])
  @@map("otp_verifications")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Meeting {
  id          String        @id @default(cuid())
  meetingCode String        @unique
  title       String
  description String?
  hostId      String
  status      MeetingStatus @default(SCHEDULED)
  roomMode    RoomMode      @default(MEETING)
  password    String?
  passcodeEncrypted String? @db.Text
  participantLimit Int     @default(100)
  isLocked    Boolean     @default(false)
  scheduledAt    DateTime?
  scheduledEndAt DateTime?
  durationMinutes Int?
  startedAt   DateTime?
  endedAt     DateTime?
  durationLimitReachedAt DateTime?
  jitsiRoom   String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  host          User             @relation("MeetingHost", fields: [hostId], references: [id])
  settings      MeetingSettings?
  participants  Participant[]
  registrants   MeetingRegistrant[]
  chatMessages  ChatMessage[]
  youtubeStream YouTubeStream?

  @@index([hostId])
  @@index([status])
  @@index([scheduledAt])
  @@map("meetings")
}

model MeetingSettings {
  id                       String   @id @default(cuid())
  meetingId                String   @unique
  chatEnabled              Boolean  @default(true)
  chatMode                 ChatMode @default(EVERYONE)
  reactionsEnabled         Boolean  @default(true)
  raiseHandEnabled         Boolean  @default(true)
  screenShareEnabled       Boolean  @default(true)
  screenShareHostOnly      Boolean  @default(false)
  waitingRoomEnabled       Boolean  @default(false)
  participantRenameEnabled Boolean  @default(false)
  participantMicAccess     Boolean  @default(true)
  coHostPermissionsEnabled Boolean  @default(true)
  autoMuteParticipants     Boolean  @default(false)
  registrationRequired     Boolean  @default(false)

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_settings")
}

model MeetingRegistrant {
  id          String   @id @default(cuid())
  meetingId   String
  fullName    String
  email       String
  phone       String?
  company     String?
  designation String?
  createdAt   DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, email])
  @@index([meetingId])
  @@map("meeting_registrants")
}

model Participant {
  id           String            @id @default(cuid())
  meetingId    String
  userId       String?
  displayName  String
  role         ParticipantRole   @default(PARTICIPANT)
  status       ParticipantStatus @default(WAITING)
  isMuted      Boolean           @default(false)
  isVideoOff   Boolean           @default(false)
  isOnStage    Boolean           @default(true)
  micAllowed   Boolean           @default(true)
  cameraAllowed Boolean          @default(true)
  handRaised   Boolean           @default(false)
  handRaisedAt DateTime?
  joinedAt     DateTime          @default(now())
  leftAt       DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@map("participants")
}

model ChatMessage {
  id         String   @id @default(cuid())
  meetingId  String
  senderId   String
  content    String
  isHostOnly Boolean  @default(false)
  createdAt  DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id])

  @@index([meetingId, createdAt])
  @@map("chat_messages")
}

model YouTubeAccount {
  id                   String   @id @default(cuid())
  userId               String   @unique
  channelId            String
  channelName          String
  channelUrl           String?
  accessToken          String   @db.Text
  refreshToken         String   @db.Text
  tokenExpiresAt       DateTime
  liveStreamingEnabled Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("youtube_accounts")
}

model YouTubeStream {
  id          String                 @id @default(cuid())
  meetingId   String                 @unique
  provider    StreamingProviderType  @default(YOUTUBE_RTMP)
  title       String?
  broadcastId String?
  streamId    String?
  streamKey   String?                @db.Text
  rtmpUrl     String?
  watchUrl    String?
  visibility  StreamVisibility       @default(PRIVATE)
  status      StreamStatus           @default(IDLE)
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime               @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("youtube_streams")
}

// ─── Webinars (architecture prep — not fully implemented) ───

model Webinar {
  id                  String              @id @default(cuid())
  hostId              String
  title               String
  description         String?
  type                WebinarType         @default(LIVE)
  status              WebinarStatus       @default(DRAFT)
  videoSourceProvider VideoSourceProvider @default(YOUTUBE)
  videoSourceUrl      String?
  videoSourceId       String?
  attendeeLimit       Int                 @default(100)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  host       User                @relation("WebinarHost", fields: [hostId], references: [id])
  schedules  WebinarSchedule[]
  moderators WebinarModerator[]

  @@index([hostId])
  @@index([status])
  @@map("webinars")
}

model WebinarSchedule {
  id              String   @id @default(cuid())
  webinarId       String
  startsAt        DateTime
  endsAt          DateTime
  recurrenceRule  String?
  createdAt       DateTime @default(now())

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId, startsAt])
  @@map("webinar_schedules")
}

model WebinarModerator {
  id         String               @id @default(cuid())
  webinarId  String
  email      String
  userId     String?
  role       WebinarModeratorRole @default(MODERATOR)
  assignedAt DateTime             @default(now())

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@unique([webinarId, email])
  @@index([webinarId])
  @@map("webinar_moderators")
}

model RecordingSession {
  id         String                @id @default(cuid())
  meetingId  String?
  userId     String
  provider   RecordingProviderType
  externalId String?
  status     StreamStatus          @default(IDLE)
  watchUrl   String?
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime              @default(now())

  @@index([meetingId])
  @@index([userId])
  @@map("recording_sessions")
}

model SubscriptionPayment {
  id                String           @id @default(cuid())
  userId            String
  plan              SubscriptionPlan
  amountInr         Int
  currency          String           @default("INR")
  status            String           @default("pending")
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("subscription_payments")
}

model PendingPayment {
  id                    String           @id @default(cuid())
  userId                String           @map("user_id")
  name                  String
  email                 String
  plan                  SubscriptionPlan
  paymentStatus         String           @default("pending") @map("payment_status")
  razorpayPaymentLinkId String?          @map("razorpay_payment_link_id")
  createdAt             DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([paymentStatus])
  @@map("pending_payments")
}

model RoadmapVote {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  featureKey String   @map("feature_key")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey])
  @@index([featureKey])
  @@map("roadmap_votes")
}
