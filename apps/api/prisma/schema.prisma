generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum PlanStatus {
  ACTIVE
  INACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  MANUAL
}

enum ActivityAction {
  LOGIN
  LOGOUT
  MEETING_CREATED
  MEETING_JOINED
  MEETING_ENDED
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum ParticipantRole {
  HOST
  CO_HOST
  PANELIST
  PARTICIPANT
  MODERATOR
}

enum RoomMode {
  MEETING
  WEBINAR
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum WebinarType {
  LIVE
  EVERGREEN
}

enum WebinarStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
  ARCHIVED
}

enum VideoSourceProvider {
  YOUTUBE
  BOLD_VIDEO
}

enum WebinarModeratorRole {
  MODERATOR
  CO_MODERATOR
}

enum RecordingProviderType {
  YOUTUBE
  BOLD_VIDEO
  STORAGE
}

enum ParticipantStatus {
  WAITING
  ADMITTED
  REMOVED
  LEFT
}

enum ChatMode {
  EVERYONE
  HOST_ONLY
  HOST_PANELISTS
  DISABLED
}

enum StreamVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum StreamStatus {
  IDLE
  LIVE
  ENDED
  ERROR
}

enum StreamingProviderType {
  NONE
  YOUTUBE_RTMP
  CUSTOM_RTMP
}

enum RegistrationFieldType {
  TEXT
  TEXTAREA
  DROPDOWN
  RADIO
  CHECKBOX
  EMAIL
  PHONE
}

enum StandardRegistrationField {
  FULL_NAME
  EMAIL
  PHONE
  CITY
  STATE
  COUNTRY
  COMPANY
  DESIGNATION
  WEBSITE
  LINKEDIN
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  JOINED
}

enum OtpChannel {
  EMAIL
  WHATSAPP
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members UserProfile[]

  @@map("organizations")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  role          UserRole  @default(USER)
  subscriptionPlan SubscriptionPlan @default(FREE)
  subscriptionExpiresAt DateTime?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  isVerified    Boolean   @default(false)
  verifiedAt    DateTime?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  profile        UserProfile?
  subscription   Subscription?
  hostedMeetings Meeting[]       @relation("MeetingHost")
  hostedWebinars Webinar[]       @relation("WebinarHost")
  participants   Participant[]
  youtubeAccount YouTubeAccount?
  chatMessages   ChatMessage[]
  subscriptionPayments SubscriptionPayment[]
  pendingPayments      PendingPayment[]
  roadmapVotes         RoadmapVote[]
  activityLogs         ActivityLog[]

  @@index([role])
  @@index([isActive])
  @@index([subscriptionPlan])
  @@map("users")
}

model UserProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  mobile           String?
  country          String?
  organization     String?
  designation      String?
  website          String?
  linkedInUrl      String?   @map("linkedin_url")
  organizationId   String?   @map("organization_id")
  profileCompletedAt DateTime? @map("profile_completed_at")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationRef Organization? @relation(fields: [organizationId], references: [id])

  @@index([country])
  @@index([organizationId])
  @@map("user_profiles")
}

model Subscription {
  id              String           @id @default(cuid())
  userId          String           @unique
  planName        SubscriptionPlan @default(FREE) @map("plan_name")
  planStatus      PlanStatus       @default(ACTIVE) @map("plan_status")
  planStartDate   DateTime?        @map("plan_start_date")
  planExpiryDate  DateTime?        @map("plan_expiry_date")
  customerId      String?          @map("customer_id")
  subscriptionId  String?          @map("subscription_id")
  paymentStatus   String           @default("none") @map("payment_status")
  paymentProvider PaymentProvider? @map("payment_provider")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([planName, planStatus])
  @@index([paymentProvider])
  @@map("subscriptions")
}

model ActivityLog {
  id         String         @id @default(cuid())
  userId     String?
  action     ActivityAction
  entityType String?        @map("entity_type")
  entityId   String?        @map("entity_id")
  metadata   Json?
  ipAddress  String?        @map("ip_address")
  userAgent  String?        @map("user_agent")
  createdAt  DateTime       @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

model OtpVerification {
  id        String    @id @default(cuid())
  email     String
  codeHash  String
  channel   OtpChannel @default(EMAIL)
  expiresAt DateTime
  attempts  Int       @default(0)
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([email, createdAt])
  @@map("otp_verifications")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Meeting {
  id          String        @id @default(cuid())
  meetingCode String        @unique
  title       String
  description String?
  hostId      String
  hostName    String?       @map("host_name")
  hostEmail   String?       @map("host_email")
  status      MeetingStatus @default(SCHEDULED)
  roomMode    RoomMode      @default(MEETING)
  password    String?
  passcodeEncrypted String? @db.Text
  participantLimit Int     @default(100)
  isLocked    Boolean     @default(false)
  scheduledAt    DateTime?
  scheduledEndAt DateTime?
  durationMinutes Int?
  startedAt   DateTime?
  endedAt     DateTime?
  durationLimitReachedAt DateTime?
  jitsiRoom   String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  host          User             @relation("MeetingHost", fields: [hostId], references: [id])
  settings      MeetingSettings?
  participants  Participant[]
  registrationForm MeetingRegistrationForm?
  registrations MeetingRegistration[]
  chatMessages  ChatMessage[]
  youtubeStream YouTubeStream?

  @@index([hostId])
  @@index([status])
  @@index([scheduledAt])
  @@map("meetings")
}

model MeetingSettings {
  id                       String   @id @default(cuid())
  meetingId                String   @unique
  chatEnabled              Boolean  @default(true)
  chatMode                 ChatMode @default(EVERYONE)
  reactionsEnabled         Boolean  @default(true)
  raiseHandEnabled         Boolean  @default(true)
  screenShareEnabled       Boolean  @default(true)
  screenShareHostOnly      Boolean  @default(false)
  waitingRoomEnabled       Boolean  @default(false)
  participantRenameEnabled Boolean  @default(false)
  participantMicAccess     Boolean  @default(true)
  coHostPermissionsEnabled Boolean  @default(true)
  autoMuteParticipants     Boolean  @default(false)
  registrationRequired     Boolean  @default(false)

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_settings")
}

model MeetingRegistrationForm {
  id                    String   @id @default(cuid())
  meetingId             String   @unique
  requireApproval       Boolean  @default(false) @map("require_approval")
  autoApprove           Boolean  @default(true) @map("auto_approve")
  sendConfirmationEmail Boolean  @default(false) @map("send_confirmation_email")
  limitRegistrations    Boolean  @default(false) @map("limit_registrations")
  maxRegistrations      Int?     @map("max_registrations")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  meeting       Meeting                   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  fields        MeetingRegistrationField[]
  registrations MeetingRegistration[]

  @@map("meeting_registration_forms")
}

model MeetingRegistrationField {
  id            String                     @id @default(cuid())
  formId        String
  fieldKey      String
  label         String
  fieldType     RegistrationFieldType
  standardField StandardRegistrationField?
  isRequired    Boolean                    @default(false) @map("is_required")
  isEnabled     Boolean                    @default(true) @map("is_enabled")
  isLocked      Boolean                    @default(false) @map("is_locked")
  sortOrder     Int                        @default(0) @map("sort_order")
  options       Json?
  placeholder   String?
  helpText      String?                    @map("help_text")
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  form    MeetingRegistrationForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers MeetingRegistrationAnswer[]

  @@unique([formId, fieldKey])
  @@index([formId, sortOrder])
  @@map("meeting_registration_fields")
}

model MeetingRegistration {
  id           String             @id @default(cuid())
  meetingId    String
  formId       String?
  email        String
  fullName     String             @map("full_name")
  phone        String?
  company      String?
  designation  String?
  city         String?
  state        String?
  country      String?
  website      String?
  linkedInUrl  String?            @map("linkedin_url")
  status       RegistrationStatus @default(PENDING)
  joinedAt     DateTime?          @map("joined_at")
  approvedAt   DateTime?          @map("approved_at")
  rejectedAt   DateTime?          @map("rejected_at")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  meeting Meeting                  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  form    MeetingRegistrationForm? @relation(fields: [formId], references: [id], onDelete: SetNull)
  answers MeetingRegistrationAnswer[]

  @@unique([meetingId, email])
  @@index([meetingId, status])
  @@index([formId])
  @@map("meeting_registrations")
}

model MeetingRegistrationAnswer {
  id             String @id @default(cuid())
  registrationId String @map("registration_id")
  fieldId        String @map("field_id")
  value          String @db.Text

  registration MeetingRegistration     @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  field        MeetingRegistrationField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([registrationId, fieldId])
  @@index([fieldId])
  @@map("meeting_registration_answers")
}

model Participant {
  id           String            @id @default(cuid())
  meetingId    String
  userId       String?
  displayName  String
  role         ParticipantRole   @default(PARTICIPANT)
  status       ParticipantStatus @default(WAITING)
  isMuted      Boolean           @default(false)
  isVideoOff   Boolean           @default(false)
  isOnStage    Boolean           @default(true)
  micAllowed   Boolean           @default(true)
  cameraAllowed Boolean          @default(true)
  handRaised   Boolean           @default(false)
  handRaisedAt DateTime?
  joinedAt     DateTime          @default(now())
  leftAt       DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@map("participants")
}

model ChatMessage {
  id         String   @id @default(cuid())
  meetingId  String
  senderId   String
  content    String
  isHostOnly Boolean  @default(false)
  createdAt  DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id])

  @@index([meetingId, createdAt])
  @@map("chat_messages")
}

model YouTubeAccount {
  id                   String   @id @default(cuid())
  userId               String   @unique
  channelId            String
  channelName          String
  channelUrl           String?
  accessToken          String   @db.Text
  refreshToken         String   @db.Text
  tokenExpiresAt       DateTime
  liveStreamingEnabled Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("youtube_accounts")
}

model YouTubeStream {
  id          String                 @id @default(cuid())
  meetingId   String                 @unique
  provider    StreamingProviderType  @default(YOUTUBE_RTMP)
  title       String?
  broadcastId String?
  streamId    String?
  streamKey   String?                @db.Text
  rtmpUrl     String?
  watchUrl    String?
  visibility  StreamVisibility       @default(PRIVATE)
  status      StreamStatus           @default(IDLE)
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime               @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("youtube_streams")
}

// ─── Webinars (architecture prep — not fully implemented) ───

model Webinar {
  id                  String              @id @default(cuid())
  hostId              String
  title               String
  description         String?
  type                WebinarType         @default(LIVE)
  status              WebinarStatus       @default(DRAFT)
  videoSourceProvider VideoSourceProvider @default(YOUTUBE)
  videoSourceUrl      String?
  videoSourceId       String?
  attendeeLimit       Int                 @default(100)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  host       User                @relation("WebinarHost", fields: [hostId], references: [id])
  schedules  WebinarSchedule[]
  moderators WebinarModerator[]

  @@index([hostId])
  @@index([status])
  @@map("webinars")
}

model WebinarSchedule {
  id              String   @id @default(cuid())
  webinarId       String
  startsAt        DateTime
  endsAt          DateTime
  recurrenceRule  String?
  createdAt       DateTime @default(now())

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId, startsAt])
  @@map("webinar_schedules")
}

model WebinarModerator {
  id         String               @id @default(cuid())
  webinarId  String
  email      String
  userId     String?
  role       WebinarModeratorRole @default(MODERATOR)
  assignedAt DateTime             @default(now())

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@unique([webinarId, email])
  @@index([webinarId])
  @@map("webinar_moderators")
}

model RecordingSession {
  id         String                @id @default(cuid())
  meetingId  String?
  userId     String
  provider   RecordingProviderType
  externalId String?
  status     StreamStatus          @default(IDLE)
  watchUrl   String?
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime              @default(now())

  @@index([meetingId])
  @@index([userId])
  @@map("recording_sessions")
}

model SubscriptionPayment {
  id                String           @id @default(cuid())
  userId            String
  plan              SubscriptionPlan
  amountInr         Int
  currency          String           @default("INR")
  status            String           @default("pending")
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("subscription_payments")
}

model PendingPayment {
  id                    String           @id @default(cuid())
  userId                String           @map("user_id")
  name                  String
  email                 String
  plan                  SubscriptionPlan
  paymentStatus         String           @default("pending") @map("payment_status")
  razorpayPaymentLinkId String?          @map("razorpay_payment_link_id")
  createdAt             DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([paymentStatus])
  @@map("pending_payments")
}

model RoadmapVote {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  featureKey String   @map("feature_key")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey])
  @@index([featureKey])
  @@map("roadmap_votes")
}
