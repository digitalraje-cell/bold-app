# ─── Branding (apps/web/.env.local) ─────────────────
NEXT_PUBLIC_APP_NAME=Bold
# Canonical public web URL — used for invite links, metadata, redirects
NEXT_PUBLIC_APP_URL=https://bold.robozant.com
NEXT_PUBLIC_APP_DOMAIN=bold.robozant.com
NEXT_PUBLIC_APP_DESCRIPTION=Browser-based meeting platform with YouTube recording
NEXT_PUBLIC_SUPPORT_EMAIL=support@robozant.com
NEXT_PUBLIC_COMPANY_NAME=Lifetop Academy
CONTACT_INBOX_EMAIL=support@robozant.com

# ─── Frontend (apps/web/.env.local) ───────────────────
# Required on Railway WEB service (NextAuth runs here, not on API):
AUTH_SECRET=change-me-to-a-random-secret
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret
JWT_SECRET=change-me-to-a-random-secret
# Local (Homebrew Postgres): postgresql://boldmeet:boldmeet_dev@localhost:5432/boldmeet
# Docker Compose: postgresql://postgres:postgres@localhost:5432/boldmeet
DATABASE_URL=postgresql://boldmeet:boldmeet_dev@localhost:5432/boldmeet
NEXT_PUBLIC_API_URL=http://localhost:4000
# Server-side Nest API URL for Next.js /api/backend proxy (set on Railway WEB service)
API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si
NEXT_PUBLIC_MEDIA_PROVIDER=jitsi

# Email OTP via Resend (dev: leave RESEND_API_KEY empty to log OTP to console)
RESEND_API_KEY=
EMAIL_FROM=
OTP_EXPIRY_MINUTES=10

# Razorpay Pro billing — simplest V1 path (Payment Link)
RAZORPAY_PRO_PAYMENT_LINK=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Backend (apps/api/.env) ──────────────────────────
# Local (Homebrew Postgres): postgresql://boldmeet:boldmeet_dev@localhost:5432/boldmeet
# Docker Compose: postgresql://postgres:postgres@localhost:5432/boldmeet
DATABASE_URL=postgresql://boldmeet:boldmeet_dev@localhost:5432/boldmeet
JWT_SECRET=change-me-to-a-random-secret
ENCRYPTION_KEY=change-me-32-char-encryption-key!!
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Jitsi media — Bold issues JWT; users never see Jitsi login/moderator UI.
# Production (recommended): 8x8 JaaS — https://jaas.8x8.vc/
#   JITSI_JAAS=true
#   JITSI_APP_ID=vpaas-magic-cookie-xxxxxxxx
#   JITSI_API_KEY_ID=<API Key ID / kid from JaaS console>
#   JITSI_PRIVATE_KEY=<RSA private key PEM from JaaS console>
#   (alias: JITSI_APP_SECRET)
#   NEXT_PUBLIC_JITSI_DOMAIN=8x8.vc
# Self-hosted alternative (Prosody JWT / HS256):
#   JITSI_DOMAIN=meet.example.com
#   JITSI_APP_ID=your_app_id
#   JITSI_APP_SECRET=your_shared_secret
JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=
JITSI_PRIVATE_KEY=
JITSI_APP_SECRET=
JITSI_API_KEY_ID=
JITSI_JAAS=

# ─── Production (@boldmeet/web on Railway) ─────────────
# NEXT_PUBLIC_APP_URL=https://bold.robozant.com
# NEXT_PUBLIC_APP_DOMAIN=bold.robozant.com
# AUTH_URL=https://bold.robozant.com
# NEXTAUTH_URL=https://bold.robozant.com
# NEXT_PUBLIC_API_URL=https://api.bold.robozant.com
# API_URL=https://api.bold.robozant.com
# NEXT_PUBLIC_SOCKET_URL=https://api.bold.robozant.com
# NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si
# EMAIL_FROM=Bold <onboarding@resend.dev>

# ─── Production (@boldmeet/api on Railway) ───────────
# CORS_ORIGIN=https://bold.robozant.com
# AUTH_URL=https://bold.robozant.com
