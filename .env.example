# ─── Branding (apps/web/.env.local) ─────────────────
NEXT_PUBLIC_APP_NAME=Bold
# Canonical public web URL — used for invite links, metadata, redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
NEXT_PUBLIC_APP_DESCRIPTION=Browser-based meeting platform with YouTube recording
NEXT_PUBLIC_SUPPORT_EMAIL=support@bold.robozant.com

# ─── Frontend (apps/web/.env.local) ───────────────────
# Required on Railway WEB service (NextAuth runs here, not on API):
AUTH_SECRET=change-me-to-a-random-secret
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret
JWT_SECRET=change-me-to-a-random-secret
DATABASE_URL=postgresql://boldmeet:boldmeet_dev@localhost:5432/boldmeet
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si

# Email OTP via Resend (dev: leave RESEND_API_KEY empty to log OTP to console)
RESEND_API_KEY=
EMAIL_FROM=
OTP_EXPIRY_MINUTES=10

# ─── Backend (apps/api/.env) ──────────────────────────
DATABASE_URL=postgresql://boldmeet:boldmeet_dev@localhost:5432/boldmeet
JWT_SECRET=change-me-to-a-random-secret
ENCRYPTION_KEY=change-me-32-char-encryption-key!!
CORS_ORIGIN=http://localhost:3000
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# YouTube OAuth (separate from Google auth) — prep only
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4000/youtube/callback

# Jitsi (optional, for self-hosted)
JITSI_APP_ID=
JITSI_APP_SECRET=

# ─── Production (@boldmeet/web on Railway) ─────────────
# NEXT_PUBLIC_APP_URL=https://bold.robozant.com
# NEXT_PUBLIC_APP_DOMAIN=bold.robozant.com
# AUTH_URL=https://bold.robozant.com
# NEXTAUTH_URL=https://bold.robozant.com
# NEXT_PUBLIC_API_URL=https://api.bold.robozant.com
# NEXT_PUBLIC_SOCKET_URL=https://api.bold.robozant.com
# EMAIL_FROM=BoldMeet <onboarding@resend.dev>

# ─── Production (@boldmeet/api on Railway) ───────────
# CORS_ORIGIN=https://bold.robozant.com
# AUTH_URL=https://bold.robozant.com
